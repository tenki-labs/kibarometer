# kibarometer fetcher crontab. Rendered by fetcher-entrypoint.sh which
# expands the bearer-token + admin-URL placeholders at container start.
# The expanded crontab calls the admin's bearer-authed endpoints which do
# the actual NAV fetch + DB writes.

# NAV ingest. Once-daily steady-state poll of the live head page for new
# events (post-launch labour-market traffic is light — daily is plenty).
# The historical catch-up is a button-driven one-shot via the BACKFILL
# button on /admin/jobs (fastForwardAction → fastForwardNav + backfillNav
# loop). The route handler also short-circuits if app_settings.cron_paused
# is true (operator can toggle from the same admin page) or if a
# button-driven drain is in flight. -m 90 gives slack on top of the 60 s
# wall budget for HTTP + final DB write.
0 6 * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/backfill-nav > /var/log/last-backfill.log 2>&1 || logger -s "kiba-fetcher: backfill-nav failed at $(date -Iseconds)"
# Enrichment: per-posting GET /api/v1/feedentry/{uuid} for ACTIVE postings
# missing detail. ≤200 fetches or 60 s wall per batch. Runs on the :05 offset
# to stay clear of the :00/:15/:30/:45 backfill ticks. No-op when the queue
# is empty. -m 90 gives slack on top of the 60s wall budget.
5,20,35,50 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/enrich-nav > /var/log/last-enrich.log 2>&1 || logger -s "kiba-fetcher: enrich-nav failed at $(date -Iseconds)"
# Snapshot refresh: recomputes the six dashboard tables in one transaction.
# 04:00 server time (after the 03:00 backup, before morning traffic). One
# run per day is enough — the dashboard reads pre-computed rows; the tag-time
# is shown as "Sist oppdatert" so users see the freshness.
0 4 * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 120 ${ADMIN_URL}/admin/api/jobs/refresh-snapshots > /var/log/last-snapshots.log 2>&1 || logger -s "kiba-fetcher: refresh-snapshots failed at $(date -Iseconds)"
# NAV retag: re-apply the current canonical keyword matcher to every
# nav_postings row. Forward-only ingest means historical rows retain the
# matcher's verdict from their ingest time — without a periodic retag, the
# is_ai flag drifts as canonical keywords get promoted (see /arbeidsmarked
# Temperatur card +676% incident, May 10 2026). reprocessNavPostings
# chains into refreshSnapshots on success, so the dashboard is fresh
# before the daily 04:00 refresh tick runs. Sundays 03:30 UTC — well
# before the 04:00 daily snapshot, after the 03:00 backup. -m 1800 covers
# ~370k rows at PAGE=1000 with conservative slack.
30 3 * * 0 curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 1800 ${ADMIN_URL}/admin/api/jobs/reprocess > /var/log/last-nav-reprocess.log 2>&1 || logger -s "kiba-fetcher: nav reprocess failed at $(date -Iseconds)"
# LLM Tier 1 (discovery): verbatim AI-skill phrase extraction on every new
# posting. K=15 rows per tick, ~3 s/call on Gemma 3 4B-IT 4-bit ≈ 45 s/tick.
# -m 90 gives slack above the 60 s wall budget. Offset from backfill
# (:00,:15,:30,:45) and enrich (:05,:20,:35,:50) so calls don't pile up on
# the Mac. No-op when MLX_API_KEY is unset or a previous tick still active.
8,23,38,53 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/llm-discover > /var/log/last-llm-discover.log 2>&1 || logger -s "kiba-fetcher: llm-discover failed at $(date -Iseconds)"
# LLM Tier 2 (classification): assign taxonomy categories to is_ai postings.
# K=4 rows per tick (Tier 2 is slower than Tier 1 — full description + full
# taxonomy + rationale ≈ 12 s/call). Offset 3 min from Tier 1 so the Mac
# never sees overlapping calls. Skips silently when taxonomy or active
# tier2 prompt is missing.
11,26,41,56 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/llm-classify > /var/log/last-llm-classify.log 2>&1 || logger -s "kiba-fetcher: llm-classify failed at $(date -Iseconds)"
# Media discover: poll active sources' RSS feeds, keyword-filter on
# title+lede, enqueue matching URLs into media_url_queue. Cheap (no LLM,
# no per-article fetch). 4× per hour offset from NAV ticks so curl calls
# don't pile up on kiba-web.
2,17,32,47 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/media-discover > /var/log/last-media-discover.log 2>&1 || logger -s "kiba-fetcher: media-discover failed at $(date -Iseconds)"
# Media fetch+classify: drain media_url_queue → media_articles. Fetches
# article HTML, runs the tiered extractor, applies the keyword matcher,
# computes simhash, probes for wire-cluster matches, persists. K=20 rows
# per tick or 60 s wall, whichever first. No LLM. -m 90 covers the wall
# budget plus the final DB write.
4,9,14,19,24,29,34,39,44,49,54,59 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/media-fetch-classify > /var/log/last-media-fetch.log 2>&1 || logger -s "kiba-fetcher: media-fetch-classify failed at $(date -Iseconds)"
# Media LLM Tier 1: relevance confirmation + verbatim AI-phrase extraction.
# K=15 / tick, ~3 s/call ≈ 45 s budget. Offset from NAV Tier 1 (:08/:23/:38/:53)
# and NAV Tier 2 (:11/:26/:41/:56) so the Mac never sees overlapping calls.
6,21,36,51 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/media-llm-tier1 > /var/log/last-media-tier1.log 2>&1 || logger -s "kiba-fetcher: media-llm-tier1 failed at $(date -Iseconds)"
# Media LLM Tier 2: classify into media_categories + score stance + intensity.
# K=4 / tick, ~12 s/call. Skips silently when media_categories or active
# media_tier2 prompt is missing.
13,28,43,58 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/media-llm-tier2 > /var/log/last-media-tier2.log 2>&1 || logger -s "kiba-fetcher: media-llm-tier2 failed at $(date -Iseconds)"
# Media snapshot refresh: nightly at 04:30 UTC, offset from refresh_all_snapshots
# at 04:00 to stay clear of contention. Truncate+insert across 5 tables —
# cheap; can re-run on demand from /admin/media.
30 4 * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 120 ${ADMIN_URL}/admin/api/jobs/media-refresh-snapshots > /var/log/last-media-snapshots.log 2>&1 || logger -s "kiba-fetcher: media-refresh-snapshots failed at $(date -Iseconds)"
# brreg ingest (/oppstart). Once-daily forward poll of yesterday's
# Enhetsregisteret registrations. Runs at 06:30 UTC — 30 min after NAV's
# 06:00 daily fetch so the boxes don't compete on outbound bandwidth.
# Per-day brreg volume sits well under the 10k page-cap, so no need for
# the page-walking budget the bulk dump uses (PR 4 manual-only).
# -m 300 gives generous slack: brreg API + per-page upserts can run
# 60-120 s on a busy day.
30 6 * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 300 ${ADMIN_URL}/admin/api/jobs/brreg-ingest > /var/log/last-brreg-ingest.log 2>&1 || logger -s "kiba-fetcher: brreg-ingest failed at $(date -Iseconds)"
# brreg role enrichment (/oppstart). Drains brreg_url_queue at K=50 rows
# per tick, 60s wall budget. Polite 250ms pacing inside brreg-client →
# ~12-13s of network per tick; the rest is DB writes. -m 90 gives slack
# above the 60s budget. Offset 12,42 stays clear of NAV's :00,:15,:30,:45
# backfill ticks and the :05,:20,:35,:50 enrich ticks.
12,42 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/brreg-roles > /var/log/last-brreg-roles.log 2>&1 || logger -s "kiba-fetcher: brreg-roles failed at $(date -Iseconds)"
# brreg roles-drain watchdog (/oppstart). Detects dead full-backlog
# drains (manual rolesBurstAction or prior watchdog resume) where
# kiba-web restarted mid-loop and the JS process died. Reaps any drain
# whose last_heartbeat is stale by 3+ min (vs the ~2.5 s healthy
# cadence) and auto-resumes from wherever the pending queue is at.
# No-op when no drain is dead — just 4 small DB reads. Runs every 5 min
# so recovery from a deploy/OOM kill lands within one tick.
*/5 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 30 ${ADMIN_URL}/admin/api/jobs/brreg-roles-watchdog > /var/log/last-brreg-roles-watchdog.log 2>&1 || logger -s "kiba-fetcher: brreg-roles-watchdog failed at $(date -Iseconds)"
# brreg LLM Tier 1 (deteksjon): relevance confirmation + verbatim AI-phrase
# extraction on AI-relevant brreg companies. K=15 / tick, ~3 s/call ≈ 45 s
# budget. Offset 1,16,31,46 keeps the Mac clear of NAV Tier 1 (:08/:23/:38/:53),
# NAV Tier 2 (:11/:26/:41/:56), media Tier 1 (:06/:21/:36/:51), and media
# Tier 2 (:13/:28/:43/:58). Skips silently when MLX_API_KEY is unset, when
# the brreg_tier1 prompt is missing, or when a previous tick is still active.
1,16,31,46 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/brreg-llm-tier1 > /var/log/last-brreg-tier1.log 2>&1 || logger -s "kiba-fetcher: brreg-llm-tier1 failed at $(date -Iseconds)"
# brreg LLM Tier 2 (kategorisering): assign brreg_categories slugs to AI
# companies. K=4 / tick, ~12 s/call. Offset 7,22,37,52 stays clear of all
# four other tier-2 ticks. Skips silently when brreg_categories or the
# brreg_tier2 prompt is missing.
7,22,37,52 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/brreg-llm-tier2 > /var/log/last-brreg-tier2.log 2>&1 || logger -s "kiba-fetcher: brreg-llm-tier2 failed at $(date -Iseconds)"
# brreg snapshot refresh (/oppstart). Truncate+insert across all five
# brreg_snapshot_* tables in one transaction — runs in seconds. Offset
# 45 min after NAV's 04:00 snapshot refresh so the two RPCs don't compete
# for Postgres locks.
45 4 * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 120 ${ADMIN_URL}/admin/api/jobs/brreg-refresh-snapshots > /var/log/last-brreg-snapshots.log 2>&1 || logger -s "kiba-fetcher: brreg-refresh-snapshots failed at $(date -Iseconds)"
# brreg financials drain (/oppstart). Hourly tick at :18 — drains K=50
# AI-flagged orgnrs/tick from Regnskapsregisteret. 180-day per-orgnr retry
# cadence means most ticks no-op once the backfill is ajour. Offset :18
# stays clear of NAV :05/:20/:35/:50 enrich, brreg :12/:42 roles, NAV
# Tier 1 :08/:23/:38/:53, and media-fetch-classify */5 (:04…:59 step 5).
# -m 90 covers the 60 s wall budget inside drainFinancials() plus slack.
# Each fetch is a single HTTP to data.brreg.no/regnskapsregisteret/regnskap
# — no LLM, no MLX contention.
18 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 "${ADMIN_URL}/admin/api/jobs/brreg-financials?k=50" > /var/log/last-brreg-financials.log 2>&1 || logger -s "kiba-fetcher: brreg-financials failed at $(date -Iseconds)"
# brreg financials full-drain watchdog. Detects dead manual backfill
# bursts (kiba-web restart killed the JS process; heartbeat stale 3+ min)
# and auto-resumes from wherever fetch_state is at. No-op when no drain
# is dead — just 4 small DB reads. Offset 2-57/5 keeps separation from
# the brreg-roles-watchdog at */5 so the two cheap watchdogs don't share
# every tick. -m 30 since worst case is one DB scan + spawn.
2-57/5 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 30 ${ADMIN_URL}/admin/api/jobs/brreg-financials-watchdog > /var/log/last-brreg-financials-watchdog.log 2>&1 || logger -s "kiba-fetcher: brreg-financials-watchdog failed at $(date -Iseconds)"
# /offentlig — Stortinget daily fetch. Pulls the active parliamentary
# session's saker + vedtak from data.stortinget.no and upserts. Idempotent
# per session — re-fetching all saker each day is fine since per-session
# volume is small (hundreds of saker, similar vedtak) and the API has no
# delta endpoint. Runs at 07:00 UTC — 30 min after BRREG ingest at 06:30
# so the box doesn't queue overlapping outbound HTTP. -m 300 covers the
# saker + vedtak fetches plus upserts comfortably.
0 7 * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 300 ${ADMIN_URL}/admin/api/jobs/offentlig-storting-fetch > /var/log/last-offentlig-storting-fetch.log 2>&1 || logger -s "kiba-fetcher: offentlig-storting-fetch failed at $(date -Iseconds)"
# /offentlig — Stortinget Sunday retag. Re-applies the current canonical
# keyword matcher to every storting_saker + storting_vedtak row so
# historical rows pick up keyword-catalog growth (same drift pattern as
# NAV's reprocess at 03:30). Runs Sundays 04:15 UTC — after the 04:00
# daily NAV snapshot refresh, before the 04:30 media snapshot refresh.
# Total corpus is small (~tens of thousands of rows); -m 600 is plenty.
15 4 * * 0 curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 600 ${ADMIN_URL}/admin/api/jobs/offentlig-storting-retag > /var/log/last-offentlig-storting-retag.log 2>&1 || logger -s "kiba-fetcher: offentlig-storting-retag failed at $(date -Iseconds)"
# /offentlig — Tier 1 (verbatim AI-phrase extraction) for Stortinget saker.
# K=15 / tick, ~3 s/call ≈ 45 s budget. Forward-only on ingest_mode='live'
# per CLAUDE.md §2. Offset :03/:18/:33/:48 keeps the Mac clear of NAV Tier 1
# (:08/:23/:38/:53), media Tier 1 (:06/:21/:36/:51), brreg Tier 1
# (:01/:16/:31/:46), and all four Tier 2 offset blocks. Skips silently
# when MLX_API_KEY is unset or the offentlig_storting_tier1 prompt is
# missing. Doffin tier1 joins this same handler once that pillar ships.
3,18,33,48 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/offentlig-llm-tier1 > /var/log/last-offentlig-tier1.log 2>&1 || logger -s "kiba-fetcher: offentlig-llm-tier1 failed at $(date -Iseconds)"
# /offentlig — Tier 2 (taxonomy slug assignment) for Stortinget saker.
# K=4 / tick, ~12 s/call ≈ 48 s budget. Gates on is_ai_relevant directly,
# not tier1_completed_at, so backfill rows get categorized too. Offset
# :10/:25/:40/:55 sits clear of NAV Tier 2 (:11/:26/:41/:56), media Tier 2
# (:13/:28/:43/:58), brreg Tier 2 (:07/:22/:37/:52). Skips silently when
# storting_categories or the offentlig_storting_tier2 prompt is missing.
10,25,40,55 * * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 90 ${ADMIN_URL}/admin/api/jobs/offentlig-llm-tier2 > /var/log/last-offentlig-tier2.log 2>&1 || logger -s "kiba-fetcher: offentlig-llm-tier2 failed at $(date -Iseconds)"
# /offentlig snapshot refresh. Truncate+insert across the seven
# offentlig_snapshot_* tables — runs in seconds. Offset 05:00 UTC so the
# four snapshot RPCs don't queue: NAV at 04:00, media at 04:30, brreg at
# 04:45, offentlig here. Storting-only sub-functions populate today;
# doffin sub-functions land in a later migration via CREATE OR REPLACE.
0 5 * * * curl -fsS -X POST -H "Authorization: Bearer ${FETCHER_TOKEN}" -m 120 ${ADMIN_URL}/admin/api/jobs/offentlig-refresh-snapshots > /var/log/last-offentlig-snapshots.log 2>&1 || logger -s "kiba-fetcher: offentlig-refresh-snapshots failed at $(date -Iseconds)"
